      <aliases enabled='yes' />
      <column caption='Avg Profit Overall' datatype='real' name='[Avg Sales Overall (copy)_0808718995349507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : AVG(IF YEAR([Order Date]) = &#13;&#10;{MAX(YEAR([Order Date]))}&#13;&#10;THEN [Total CY Sales (copy)_1231479725998085]  END ) }' />
      </column>
      <column caption='Avg Profit State wise' datatype='real' name='[Avg Sales State wise (copy)_0808718995427332]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [State/Province] : AVG([Total CY Sales (copy)_1231479725998085]) }' />
      </column>
      <column caption='Avg Sales State wise' datatype='real' name='[Calculation_0808718988972032]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [State/Province] : AVG([Calculation_1231479690338304]) }' />
      </column>
      <column caption='Avg Sales Overall' datatype='real' name='[Calculation_0808718989516801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : AVG(IF YEAR([Order Date]) = &#13;&#10;{MAX(YEAR([Order Date]))}&#13;&#10;THEN [Calculation_1231479690338304]  END ) }' />
      </column>
      <column caption='Sales Avg Color' datatype='string' name='[Calculation_0808718992539650]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Calculation_0808718988972032] &lt; [Calculation_0808718989516801]&#13;&#10;then &apos;Below Average&apos;&#13;&#10;elseif&#13;&#10;[Calculation_0808718988972032] &gt; [Calculation_0808718989516801]&#13;&#10;then &apos;Above Average&apos;&#13;&#10;ELSEIF &#13;&#10;[Calculation_0808718988972032] = [Calculation_0808718989516801]&#13;&#10;then &apos;Equal to Avg&apos;&#13;&#10;END' />
      </column>
      <column caption='Consumer Sales' datatype='real' name='[Calculation_0808720933232647]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [Segment]=&apos;Consumer&apos; THEN&#13;&#10;[Avg Sales Overall (copy)_0808718995349507]&#13;&#10;ELSEIF  [Segment]=&apos;Corporate&apos; THEN&#13;&#10;[Avg Sales Overall (copy)_0808718995349507]&#13;&#10;ELSEIF   [Segment]=&apos;Home Office&apos; THEN&#13;&#10;[Avg Sales Overall (copy)_0808718995349507]&#13;&#10; END' />
      </column>
      <column caption='Dynamic Measure' datatype='real' name='[Calculation_1044018006458368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Case  [Parameters].[Avg Profit Overall Parameter]&#13;&#10;when &apos;Total CY Sales&apos; then [Calculation_1231479690338304]&#13;&#10;&#13;&#10;when &apos;Total CY Profit&apos; then [Total CY Sales (copy)_1231479725998085]&#13;&#10;&#13;&#10;when &apos;Total CY Qty&apos; then [Total CY Profit (copy)_1231479729901578]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Total CY Sales' datatype='real' name='[Calculation_1231479690338304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])={MAX(YEAR([Order Date]))} THEN [Sales] END' />
      </column>
      <column caption='Total PY Sales' datatype='real' name='[Calculation_1231479693045761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])={MAX(YEAR([Order Date])) -1} THEN [Sales] END' />
      </column>
      <column caption='YOY Sales' datatype='real' name='[Calculation_1231479701028866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1231479690338304])-sum([Calculation_1231479693045761]))/sum([Calculation_1231479693045761])' />
      </column>
      <column caption='YOY sales indicator' datatype='string' name='[Calculation_1231479723360260]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1231479701028866] &gt;0 THEN &quot;▲&quot; ELSE &quot;▼&quot; END' />
      </column>
      <column caption='min max sales' datatype='real' name='[Calculation_1231479736201230]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if sum([Calculation_1231479690338304])=WINDOW_MAX(sum([Calculation_1231479690338304]))&#13;&#10;then sum([Calculation_1231479690338304])&#13;&#10;ELSEIF sum([Calculation_1231479690338304])=WINDOW_MIN(sum([Calculation_1231479690338304]))&#13;&#10;then sum([Calculation_1231479690338304])&#13;&#10;else null&#13;&#10;end'>
          <table-calc ordering-type='Rows' />
        </calculation>
