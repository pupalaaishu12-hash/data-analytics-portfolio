          <datasource-dependencies datasource='federated.0jmwfe91qks1to0zz4dcd02vnl6d'>
            <column caption='Avg Profit Overall' datatype='real' name='[Avg Sales Overall (copy)_0808718995349507]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : AVG(IF YEAR([Order Date]) = &#13;&#10;{MAX(YEAR([Order Date]))}&#13;&#10;THEN [Total CY Sales (copy)_1231479725998085]  END ) }' />
            </column>
            <column caption='Avg Profit State wise' datatype='real' name='[Avg Sales State wise (copy)_0808718995427332]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [State/Province] : AVG([Total CY Sales (copy)_1231479725998085]) }' />
            </column>
            <column aggregation='Sum' datatype='real' name='[Column]' role='dimension' type='ordinal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column aggregation='Sum' datatype='integer' name='[Row]' role='dimension' type='ordinal' />
            <column caption='Profit  Avg Color' datatype='string' name='[Sales Avg Color (copy)_0808718996627461]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='if [Avg Sales State wise (copy)_0808718995427332] &lt; [Avg Sales Overall (copy)_0808718995349507]&#13;&#10;then &apos;Below Average&apos;&#13;&#10;elseif&#13;&#10;[Avg Sales State wise (copy)_0808718995427332] &gt; [Avg Sales Overall (copy)_0808718995349507]&#13;&#10;then &apos;Above Average&apos;&#13;&#10;ELSEIF &#13;&#10;[Avg Sales State wise (copy)_0808718995427332] = [Avg Sales Overall (copy)_0808718995349507]&#13;&#10;then &apos;Equal to Avg&apos;&#13;&#10;END' />
