            <column caption='Total CY Profit' datatype='real' name='[Total CY Sales (copy)_1231479725998085]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])={MAX(YEAR([Order Date]))} THEN [Profit] END' />
            </column>
